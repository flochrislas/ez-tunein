<?xml version="1.0" encoding="utf-8"?>
<!-- audio_service references its notification-button drawables (play/pause/stop/
     skip/…) by name at runtime (resources.getIdentifier), and our media-session
     small icon is likewise named only in Dart config ('drawable/ic_stat_media').
     R8 resource-shrinking in release builds can't see those references, so it
     strips them as "unused" — then building the media notification throws
     "You must specify an icon resource id to build a CustomAction", the
     foreground service never starts, and background playback dies ~20s after the
     screen turns off (with no lock-screen / notification controls at all).
     Keep them explicitly. -->
<resources xmlns:tools="http://schemas.android.com/tools"
    tools:keep="@drawable/audio_service_*,@drawable/ic_stat_media" />
